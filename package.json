{
  "name": "tsv-ledger",
  "version": "2.2.3",
  "description": "Advanced expense tracking and business intelligence platform for Texas Sunset Venues with comprehensive Amazon integration, AI-powered analysis, professional organization, and extensive testing framework",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:auto": "node auto-test.js all",
    "test:auto:unit": "node auto-test.js unit",
    "test:auto:integration": "node auto-test.js integration",
    "test:auto:e2e": "node auto-test.js e2e",
    "dev:test": "node dev-test.js",
    "test:workflow": "./test-workflow.sh",
    "test:unit": "npx jest tests/unit --coverage --coverageDirectory=coverage/unit",
    "test:integration": "npx jest tests/integration --coverage --coverageDirectory=coverage/integration",
    "test:api": "newman run tests/api/postman-collection.json",
    "test:performance": "artillery run tests/performance/performance.yml",
    "test:accessibility": "npx playwright test tests/accessibility",
    "test:visual": "npx playwright test tests/visual",
    "test:coverage": "npx jest --coverage --coverageDirectory=coverage/combined --collectCoverageFrom='src/**/*.js' --collectCoverageFrom='!src/**/*.test.js'",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:api && npm run test:performance && npm run test:accessibility && npm run test:visual",
    "lint": "npx eslint src/ tests/ --fix",
    "format": "npx prettier --write src/ tests/ public/js/ public/components/",
    "test-quick": "node quick-test.js",
    "test-ss": "node quick-test.js ss",
    "test-categories": "node quick-test.js categories",
    "test-interactive": "node quick-test.js interactive",
    "test:ai-visual": "node ai-visual-test.js full",
    "test:ai-visual:nav": "node ai-visual-test.js nav",
    "test:ai-visual:analysis": "node ai-visual-test.js analysis",
    "test:ai-visual:responsive": "node ai-visual-test.js responsive",
    "test-cli": "./smart-test.sh test cli",
    "test-amazon": "node tests/test-amazon-edit-feature.js",
    "test-ux": "node tests/test-ux-amazon-edit.js",
    "test-complete": "node tests/test-complete.js",
    "test-full": "node standalone-test.js full",
    "test-standalone": "node standalone-test.js quick",
    "test:pw": "node tests/pw/benefits-smoke.test.js",
    "test-menu-api": "node tests/test-menu-api.js",
    "test-menu-rendering": "node tests/test-menu-rendering.js",
    "test-menu-navigation": "node tests/quick-nav-check.js",
    "test-menu-console": "node tests/navigation-error-test.js",
    "test-menu-e2e": "node tests/navigation-e2e-comprehensive.js",
    "test-menu-suite": "node tests/navigation-master-suite.js",
    "test-menu": "npm run test-menu-suite",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:install": "npx playwright install",
    "monitor:adherence": "node adherence-monitor.js",
    "test:e2e:ci": "npx playwright install && npx playwright test --config=playwright.config.js",
    "playwright:headed-local": "node node_modules/@playwright/test/cli.js test --headed",
    "playwright:inspect-local": "PWDEBUG=1 node node_modules/@playwright/test/cli.js test",
    "playwright:trace-local": "node node_modules/@playwright/test/cli.js test --trace on",
    "toggler-nonmax": "node tests/toggler-nonmax.js",
    "toggler-smoke": "node tests/toggler-smoke.js",
    "overlay-sim": "node tests/overlay-simulation.js",
    "accessibility-scan": "node tests/accessibility-scan.js",
    "toggler-multi": "node tests/toggler-multi-sizes.js",
    "toggler-maximized": "node tests/toggler-maximized.js",
    "server-start": "./smart-test.sh start",
    "server-stop": "./smart-test.sh stop",
    "server-status": "./smart-test.sh status",
    "docs:generate": "npx jsdoc src/ -d docs/api/",
    "index:check": "echo 'Run Copilot Chat with #codebase to validate indexing'"
  },
  "dependencies": {
    "@playwright/test": "^1.57.0",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.0.0",
    "express": "^4.18.2",
    "form-data": "^4.0.4",
    "jest-junit": "^16.0.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^24.34.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "artillery": "^2.0.8",
    "newman": "^6.1.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.2.0",
    "puppeteer-core": "^23.0.0",
    "supertest": "^6.3.4"
  }
}
