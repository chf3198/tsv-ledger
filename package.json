{
  "name": "tsv-ledger",
  "version": "2.2.2",
  "description": "Advanced expense tracking and business intelligence platform for Texas Sunset Venues with comprehensive Amazon integration, AI-powered analysis, professional organization, and extensive testing framework",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-analysis-unit.js",
    "test-quick": "node quick-test.js",
    "test-ss": "node quick-test.js ss",
    "test-categories": "node quick-test.js categories",
    "test-interactive": "node quick-test.js interactive",
    "test-backend": "./smart-test.sh test quick",
    "test-cli": "./smart-test.sh test cli",
    "test-amazon": "node tests/test-amazon-edit-feature.js",
    "test-ux": "node tests/test-ux-amazon-edit.js",
    "test-complete": "node tests/test-complete.js",
    "test-full": "node standalone-test.js full",
    "test-standalone": "node standalone-test.js quick",
    "test:pw": "node tests/pw/benefits-smoke.test.js",
  "test:all": "./scripts/test-all.sh",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:install": "npx playwright install",
    "server-start": "./smart-test.sh start",
    "server-stop": "./smart-test.sh stop",
    "server-status": "./smart-test.sh status"
  },
  "dependencies": {
    "csv-parser": "^3.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
  "puppeteer": "^21.11.0",
  "@playwright/test": "^1.37.0"
  }
}
